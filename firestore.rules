rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // A user can only read/write their own profile doc (maps them to a household).
    match /users/{uid} {
      allow read, write: if isSignedIn() && request.auth.uid == uid;
    }

    match /households/{householdId} {
      // Membership is recorded on the household doc itself.
      function isMember() {
        return isSignedIn() && request.auth.uid in resource.data.memberUids;
      }
      // On create, the caller must list themselves as a member.
      function willBeMember() {
        return isSignedIn() && request.auth.uid in request.resource.data.memberUids;
      }

      allow read: if isMember();
      allow create: if willBeMember();
      // Allow updates by current members who remain members (e.g. inviting another parent).
      allow update: if isMember() && willBeMember();

      // All household data (groups, accounts, transactions, recurringRules, …) is
      // readable/writable only by members of the parent household.
      match /{document=**} {
        allow read, write: if isSignedIn() &&
          request.auth.uid in
            get(/databases/$(database)/documents/households/$(householdId)).data.memberUids;
      }
    }
  }
}
